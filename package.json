{
  "name": "ryze-technology-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/generate-sitemap.mjs",
    "prerender": "node scripts/prerender.mjs",
    "build:prerender": "npm run build && npm run prerender",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest --run",
    "test:ci": "FAST_CHECK_NUM_RUNS=100 vitest --run",
    "budget": "node scripts/check-bundle-budget.mjs",
    "verify": "npm run build && npm run test:ci && npm run budget",
    "lighthouse": "lhci autorun"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@types/three": "^0.169.0",
    "framer-motion": "^11.18.2",
    "gsap": "^3.15.0",
    "lenis": "^1.3.24",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^6.26.2",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "fast-check": "^4.8.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^4.1.9"
  }
}
